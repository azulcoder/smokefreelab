# Copy this file to .env and fill in your values.
# Never commit the real .env file.

# Google Cloud project (must have BigQuery Sandbox enabled).
# Get yours from: https://console.cloud.google.com
GCP_PROJECT_ID=your-project-id-here

# BigQuery location (keep "US" for the public GA4 sample dataset).
BQ_LOCATION=US

# Public GA4 sample dataset — do not change unless you point at a private GA4 export.
GA4_DATASET=ga4_obfuscated_sample_ecommerce
GA4_PROJECT=bigquery-public-data

# Local output directory for notebook artifacts (created at runtime).
OUTPUT_DIR=./output
